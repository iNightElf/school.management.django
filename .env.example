# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_BUCKET=student-photos

# PostgreSQL (for management commands that bypass Django ORM)
SUPABASE_DSN=postgresql://user:password@host:5432/dbname

# PostgreSQL (Django ORM)
DB_NAME=your-database-name
DB_USER=your-database-user
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432
DB_SSLMODE=prefer

# Firebase Realtime Database
FIREBASE_URL=https://your-project-default-rtdb.firebaseio.com/school.json
FIREBASE_RESULTS_URL=https://your-project-default-rtdb.firebaseio.com/school/results


GEMINI_API_KEY=your-gemini-api-key-here