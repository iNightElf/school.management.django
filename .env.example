# ── Django ──
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-app-name.alwaysdata.net,localhost,127.0.0.1

# ── Frontend (GitHub Pages) ──
FRONTEND_URL=https://iNightElf.github.io
CORS_ORIGINS=https://iNightElf.github.io

# ── PostgreSQL (Supabase) ──
DB_NAME=postgres
DB_USER=postgres.xxxxxxxx
DB_PASSWORD=your-supabase-db-password
DB_HOST=aws-0-ap-south-1.pooler.supabase.com
DB_PORT=6543
DB_SSLMODE=require

# ── Supabase Storage ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_BUCKET=student-photos

# ── AI ──
GEMINI_API_KEY=your-gemini-api-key-here

# ── Email ──
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com
